#!/bin/bash
# 重启应用 + 就绪性检测 + 路由解析 + 截图 协调脚本
# 作为 Stop Hook 使用
#
# 执行流程：
# 1. 校验项目配置和先决条件
# 2. 调用 /__genie__/restart 重启应用并检测就绪性
# 3. 执行 parse-routes 生成 pages.json
# 4. 后台截图
#
# Hook 响应协议：
# stdout 输出 JSON: {"continue": bool, "reason": "string"}
# exit 0 = 正常通过, exit 2 = 阻断 AI

set -uo pipefail

# ============================================================================
# 日志
# ============================================================================

LOG_DIR="/tmp/.genie/logs"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/ensure-app-ready.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"
}

# ============================================================================
# Hook 响应输出
# ============================================================================

# 输出 Hook JSON 响应到 stdout
# 用法: hook_result <continue:true|false> <reason>
hook_result() {
    local continue_val="$1"
    local reason="$2"
    # 转义 reason 中的特殊字符用于 JSON
    local escaped_reason
    escaped_reason=$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$reason" 2>/dev/null)
    echo "{\"continue\": ${continue_val}, \"reason\": ${escaped_reason}}"
}

log "========== 脚本开始执行 =========="

# ============================================================================
# 读取 stdin
# ============================================================================

INPUT=$(cat)
log "stdin INPUT: ${INPUT}"

PROJECT_DIR="${CODEBUDDY_PROJECT_DIR:-.}"
CLOUDSTUDIO_CONFIG="$PROJECT_DIR/.cloudstudio"

# ============================================================================
# 先决条件检查
# ============================================================================

if [ ! -f "$CLOUDSTUDIO_CONFIG" ]; then
    log "未找到 .cloudstudio 配置，跳过"
    exit 0
fi

# ============================================================================
# 定位自身所在目录（用于调用同目录下的其他脚本）
# ============================================================================

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ============================================================================
# 重启应用并检测就绪性
# ============================================================================

# 解析 stop_hook_active：为 true 表示已阻止过一次，跳过检测
STOP_HOOK_ACTIVE=$(echo "$INPUT" | python3 -c "import sys,json; print('true' if json.load(sys.stdin).get('stop_hook_active') else 'false')" 2>/dev/null)

RESTART_URL="http://127.0.0.1:55221/__genie__/restart"
if [ "$STOP_HOOK_ACTIVE" = "true" ]; then
    RESTART_URL="${RESTART_URL}?skipCheck=true"
    log "stop_hook_active=true，跳过就绪性检测"
fi

log "调用 ${RESTART_URL} 重启应用..."
RESTART_RESPONSE=$(curl -s -X POST "$RESTART_URL" 2>&1)
CURL_EXIT_CODE=$?
log "restart 响应 (curl exit: ${CURL_EXIT_CODE}): ${RESTART_RESPONSE}"

# curl 连接失败（如 ProxyServer 未启动），阻断并提示
if [ "$CURL_EXIT_CODE" -ne 0 ]; then
    log "基础网关设施未启动 (curl exit: ${CURL_EXIT_CODE})"
    hook_result false "<system-reminder>基础网关设施未启动，无法正常跳转预览，请保持沉默，当用户询问时请友好的向用户提示在反馈区域填写反馈帮助我们定位。</system-reminder>"
    exit 2
fi

# 解析 success 字段
RESTART_SUCCESS=$(echo "$RESTART_RESPONSE" | python3 -c "import sys,json; print('true' if json.load(sys.stdin).get('success') else 'false')" 2>/dev/null)

if [ "$RESTART_SUCCESS" != "true" ]; then
    # 提取 reason 字段
    RESTART_REASON=$(echo "$RESTART_RESPONSE" | python3 -c "import sys,json; print(json.load(sys.stdin).get('reason', ''))" 2>/dev/null)
    log "重启检测失败: ${RESTART_REASON}"
    hook_result false "<system-reminder>自动重启失败：${RESTART_REASON}</system-reminder>"
    exit 2
fi

log "应用重启并就绪性检测通过"

# ============================================================================
# 解析路由生成 pages.json
# ============================================================================

log "执行 parse-routes..."
if [ -f "$SCRIPT_DIR/parse-routes" ]; then
    PARSE_OUTPUT=$("$SCRIPT_DIR/parse-routes" -r . 2>&1) || {
        log "parse-routes 失败: ${PARSE_OUTPUT}（不影响后续流程）"
    }
    log "parse-routes 结果: ${PARSE_OUTPUT}"
else
    log "parse-routes 不存在，跳过"
fi

# ============================================================================
# 截图（后台运行）
# ============================================================================

SCREENSHOT_SCRIPT="$PROJECT_DIR/.genie/scripts/python/capture_screenshot.py"
SCREENSHOT_OUTPUT="$PROJECT_DIR/docs/posters/app/app-poster.png"

if [ -f "$SCREENSHOT_SCRIPT" ]; then
    log "后台截图: $SCREENSHOT_OUTPUT"
    python3 "$SCREENSHOT_SCRIPT" "$SCREENSHOT_OUTPUT" > /dev/null 2>&1 &
else
    log "截图脚本不存在，跳过"
fi

echo '{"continue": true}'
